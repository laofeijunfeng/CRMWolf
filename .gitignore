# CRMWolf 项目 Git Ignore

# ===== 前端 =====
CRM-Client/node_modules/
CRM-Client/dist/
CRM-Client/coverage/
CRM-Client/.vite/
CRM-Client/*.local

# ===== 后端 =====
CRM-Server/venv/
CRM-Server/__pycache__/
CRM-Server/**/__pycache__/
CRM-Server/*.pyc
CRM-Server/.pytest_cache/
/.pytest_cache/
CRM-Server/.coverage
CRM-Server/htmlcov/
CRM-Server/.mypy_cache/
CRM-Server/.ruff_cache/

# ===== 环境配置 =====
CRM-Server/.env
*.env.local
*.env.*.local

# ===== Secrets（敏感信息，绝不提交） =====
/secrets/
/CRM-Docs/deployment/secrets/
*.key
*.pem

# ===== Docker 开发配置（本地特有） =====
docker-compose.override.yml

# ===== IDE =====
.idea/
.vscode/
*.swp
*.swo
*~

# ===== 系统文件 =====
.DS_Store
Thumbs.db

# ===== 日志 =====
*.log
/logs/
/CRM-Server/logs/*
!/CRM-Server/logs/.gitkeep

# ===== 临时文件 =====
*.tmp
*.temp
.cache/

# ===== 上传文件 =====
CRM-Server/uploads/**.tar
CRM-Server/uploads/invoices/
CRM-Server/uploads/contracts/
# Ignore all uploaded files except .gitkeep
uploads/*
!uploads/.gitkeep

# ===== 本地工具目录 =====
.claude/
/CRM-Client/.agents/
/CRM-Client/skills-lock.json
.sdd/
.superpowers/
.gstack/

# Docker images
*.tar
