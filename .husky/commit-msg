#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# ===== Commit Message 格式校验 =====
commit_msg=$(cat "$1")

# Conventional Commits 格式
pattern="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,50}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Commit message must follow Conventional Commits format:"
  echo ""
  echo "   <type>(<scope>): <description>"
  echo ""
  echo "Types:"
  echo "   feat     - 新功能"
  echo "   fix      - 修复 bug"
  echo "   docs     - 文档变更"
  echo "   style    - 代码格式"
  echo "   refactor - 重构"
  echo "   test     - 测试"
  echo "   chore    - 构建/工具"
  echo ""
  echo "Examples:"
  echo "   feat(customer): 添加客户导出功能"
  echo "   fix(api): 修复 API 响应格式错误"
  echo "   docs: 更新 TYPESCRIPT.md 类型定义"
  echo ""
  exit 1
fi

echo "✅ Commit message format valid"