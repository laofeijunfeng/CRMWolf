#!/usr/bin/env sh
echo "🔍 Running pre-commit checks (incremental)..."

# ===== 文档位置检查 =====
CRM_DOCS_DIR="CRM-Docs"
SCRIPT_PATH="$CRM_DOCS_DIR/scripts/check-doc-location.sh"
if [ -f "$SCRIPT_PATH" ]; then
  if git diff --cached --name-only | grep -q "^CRM-Docs/"; then
    chmod +x "$SCRIPT_PATH"
    "$SCRIPT_PATH" || { echo "::error::Document location check failed (CRM-Docs 根目录只允许 README.md)"; exit 1; }
  fi
fi

# ===== 配置锁定检查 =====
LOCKED_CONFIGS="CRM-Client/tsconfig.json CRM-Client/eslint.config.js CRM-Server/pyproject.toml"
for config in $LOCKED_CONFIGS; do
  if git diff --cached --name-only | grep -q "$config"; then
    echo "::error::Modification of $config requires human approval (CRM-Docs/SPEC-CHANGELOG.md)"; exit 1
  fi
done

# ===== 前端增量检查：只对暂存的 src/**/*.{ts,vue,tsx} 跑 ESLint（硬阻断）=====
STAGED_FE=$(git diff --cached --name-only --diff-filter=d | grep -E '^CRM-Client/src/.*\.(ts|vue|tsx)$' || true)
if [ -n "$STAGED_FE" ]; then
  cd CRM-Client
  FE_REL=$(echo "$STAGED_FE" | sed 's|^CRM-Client/||')
  echo "📝 ESLint (staged: $(echo "$STAGED_FE" | grep -c .) files)..."
  echo "$FE_REL" | xargs -r npx eslint --max-warnings=0 || { echo "::error::ESLint failed on staged files"; exit 1; }
  # type-check 全量降为警告：tsc 无法增量，现成 TS 债（Users.vue 等）会让全量失败。
  # 待 preexisting TS 债清理后，此处恢复为硬阻断（对齐原 mypy 不阻断 -> 阻断演进）。
  echo "🔢 Type-check (warning only, preexisting debt pending)..."
  npm run type-check || echo "::warning::TypeScript check has issues (preexisting debt, non-blocking)"
  cd ..
fi

# ===== 后端增量检查：只对暂存的 CRM-Server/**/*.py 跑 Ruff（硬阻断）=====
STAGED_BE=$(git diff --cached --name-only --diff-filter=d | grep -E '^CRM-Server/.*\.py$' || true)
if [ -n "$STAGED_BE" ]; then
  cd CRM-Server
  BE_REL=$(echo "$STAGED_BE" | sed 's|^CRM-Server/||')
  if command -v ruff >/dev/null 2>&1; then
    echo "📝 Ruff (staged: $(echo "$STAGED_BE" | grep -c .) files)..."
    echo "$BE_REL" | xargs -r ruff check || { echo "::error::Ruff failed on staged files"; exit 1; }
  fi
  if command -v mypy >/dev/null 2>&1; then
    echo "🔢 MyPy (warning only)..."
    mypy app/ 2>/dev/null || echo "::warning::MyPy has issues (non-blocking)"
  fi
  cd ..
fi

echo "✅ Pre-commit checks passed (incremental)"
